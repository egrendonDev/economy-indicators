{
  "name": "economy-indicators",
  "version": "1.0.0",
  "description": "Economic downturn indicator dashboard - fetches data from FRED API and other sources",
  "type": "module",
  "scripts": {
    "serve": "npx serve . --listen 3000",
    "api-pull:weekly": "node scripts/api-pull-weekly.js",
    "api-pull:monthly": "node scripts/api-pull-monthly.js",
    "api-pull:quarterly": "node scripts/api-pull-quarterly.js",
    "api-pull:all": "node scripts/api-pull-weekly.js && node scripts/api-pull-monthly.js && node scripts/api-pull-quarterly.js",
    "api-pull:all:force": "node scripts/api-pull-weekly.js --force && node scripts/api-pull-monthly.js --force && node scripts/api-pull-quarterly.js --force",
    "html-scrape:multpl": "node scripts/html-scrape-multpl-shared.js",
    "run:api-pull:all:force:serve": "npm run api-pull:all:force && npx serve . --listen 3000",
    "run:html-scrape:multpl:serve": "npm run html-scrape:multpl && npx serve . --listen 3000",
    "run:file-drop:margin-debt:serve": "npm run file-drop:margin-debt && npx serve . --listen 3000",
    "run:file-drop:fha-delinquency:serve": "npm run file-drop:fha-delinquency && npx serve . --listen 3000",
    "run:file-drop:conventional-delinquency:serve": "npm run file-drop:conventional-delinquency && npx serve . --listen 3000",
    "file-drop:margin-debt": "node scripts/file-drop-margin-debt.js",
    "file-drop:fha-delinquency": "node scripts/file-drop-fha-delinquency.js",
    "file-drop:conventional-delinquency": "node scripts/file-drop-conventional-delinquency.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5",
    "xlsx": "^0.18.5",
    "pdf-parse": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
